{
  "name": "flashycardy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "dotenvx run --convention=nextjs -- sh -c 'pnpm test:unit && pnpm db:migrate:dev:programmatic && next dev'",
    "build": "dotenvx run --convention=nextjs -- next build",
    "vercel-build": "pnpm run db:migrate:prod:programmatic && next build",
    "start": "dotenvx run --convention=nextjs -- next start",
    "lint": "eslint",
    "db:generate:prod": "dotenvx run --convention=nextjs -- drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate:prod": "dotenvx run --convention=nextjs -- rizzle-kit migrate --config=drizzle.config.ts",
    "db:migrate:prod:programmatic": "dotenvx run -f .env -f .env.production -- tsx src/db/migrate.ts",
    "db:push:prod": "dotenvx run --convention=nextjs -- drizzle-kit push --config=drizzle.config.ts",
    "db:pull:prod": "dotenvx run --convention=nextjs -- drizzle-kit pull --config=drizzle.config.ts",
    "db:check:prod": "dotenvx run --convention=nextjs -- drizzle-kit check --config=drizzle.config.ts",
    "db:generate:dev": "dotenvx run --convention=nextjs -- drizzle-kit generate --config=drizzle.dev.config.ts",
    "db:migrate:dev": "dotenvx run --convention=nextjs -- drizzle-kit migrate --config=drizzle.dev.config.ts",
    "db:migrate:dev:programmatic": "dotenvx run -f .env -f .env.development -- tsx src/db/migrate.ts",
    "db:push:dev": "dotenvx run --convention=nextjs -- drizzle-kit push --config=drizzle.dev.config.ts",
    "db:pull:dev": "dotenvx run --convention=nextjs -- drizzle-kit pull --config=drizzle.dev.config.ts",
    "db:check:dev": "dotenvx run --convention=nextjs -- drizzle-kit check --config=drizzle.dev.config.ts",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:unit:watch": "vitest",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:report": "playwright test && pnpm exec playwright show-report"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.52",
    "@base-ui/react": "^1.3.0",
    "@clerk/nextjs": "^7.0.6",
    "@clerk/themes": "^2.4.57",
    "@clerk/ui": "^1.2.3",
    "@neondatabase/serverless": "^1.0.2",
    "@radix-ui/react-slot": "^1.2.4",
    "ai": "^6.0.154",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "@dotenvx/dotenvx": "^1.57.1",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.577.0",
    "next": "16.2.1",
    "next-intl": "^4.11.0",
    "officeparser": "^6.1.0",
    "pdf-parse": "^2.4.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-joyride": "^3.0.2",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^14.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
