{
  "name": "flashycardy-monorepo",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "turbo run dev --filter=@flashycardy/web",
    "build": "turbo run build --filter=@flashycardy/web",
    "lint": "turbo run lint --filter=@flashycardy/web",
    "test": "turbo run test:unit test:e2e --filter=@flashycardy/web",
    "test:unit": "turbo run test:unit --filter=@flashycardy/web",
    "test:unit:watch": "pnpm --filter @flashycardy/web exec vitest",
    "test:e2e": "turbo run test:e2e --filter=@flashycardy/web",
    "test:e2e:report": "pnpm --filter @flashycardy/web run test:e2e:report"
  },
  "devDependencies": {
    "turbo": "^2.5.4"
  }
}
