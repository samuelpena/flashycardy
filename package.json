{
  "name": "flashycardy-monorepo",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "turbo run dev --filter=@flashycardy/web",
    "dev:docs": "turbo run dev --filter=@flashycardy/docs",
    "dev:all": "turbo run dev",
    "build": "turbo run build --filter=@flashycardy/web",
    "build:docs": "turbo run build --filter=@flashycardy/docs",
    "build:all": "turbo run build",
    "lint": "turbo run lint --filter=@flashycardy/web",
    "lint:docs": "turbo run lint --filter=@flashycardy/docs",
    "lint:all": "turbo run lint",
    "test": "turbo run test:unit test:e2e --filter=@flashycardy/web",
    "test:unit": "turbo run test:unit --filter=@flashycardy/web",
    "test:unit:watch": "pnpm --filter @flashycardy/web exec vitest",
    "test:e2e": "turbo run test:e2e --filter=@flashycardy/web",
    "test:e2e:report": "pnpm --filter @flashycardy/web run test:e2e:report",
    "dev:extension": "turbo run dev --filter=@flashycardy/extension",
    "build:extension": "turbo run build --filter=@flashycardy/extension",
    "lint:extension": "turbo run lint --filter=@flashycardy/extension",
    "test:extension:unit": "turbo run test:unit --filter=@flashycardy/extension",
    "test:extension:e2e": "turbo run test:e2e --filter=@flashycardy/extension",
    "package:extension": "bash scripts/package-extension.sh",
    "dev:ios": "open apps/ios/Flashycardy/Flashycardy.xcodeproj",
    "test:ios": "cd apps/ios/Flashycardy && xcodebuild -scheme Flashycardy -destination 'platform=iOS Simulator,name=iPhone 17' test"
  },
  "devDependencies": {
    "turbo": "^2.5.4"
  }
}
