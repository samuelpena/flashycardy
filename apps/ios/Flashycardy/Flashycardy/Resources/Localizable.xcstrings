{
  "sourceLanguage" : "en",
  "strings" : {
    "#%lld" : {
      "comment" : "A label that shows the session ID.",
      "isCommentAutoGenerated" : true
    },
    "%lld" : {
      "comment" : "A label that shows the number of correct answers for a card. The argument is the number of correct answers.",
      "isCommentAutoGenerated" : true
    },
    "%lld / %lld" : {
      "comment" : "A button that shuffles the current study session.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$lld / %2$lld"
          }
        }
      }
    },
    "%lld%%" : {
      "comment" : "A badge that shows a percentage. The color of the background and text depends on the percentage.",
      "isCommentAutoGenerated" : true
    },
