import { normalizePageMap } from 'nextra/page-map'

import meta from "private-next-root-dir/content/_meta.ts";
import {metadata as architecture} from "private-next-root-dir/content/architecture.mdx?metadata";
import {metadata as getting_started} from "private-next-root-dir/content/getting-started.mdx?metadata";
import {metadata as index} from "private-next-root-dir/content/index.mdx?metadata";

export const pageMap = normalizePageMap([{
  data: meta
}, {
  name: "architecture",
  route: "/architecture",
  frontMatter: architecture
}, {
  name: "getting-started",
  route: "/getting-started",
  frontMatter: getting_started
}, {
  name: "index",
  route: "/",
  frontMatter: index
}])

export const RouteToFilepath = {
  "architecture": "architecture.mdx",
  "getting-started": "getting-started.mdx",
  "": "index.mdx"
}